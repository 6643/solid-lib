{
    "compilerOptions": {
        "baseUrl": ".",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "target": "ESNext",
        "module": "Preserve",
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "ignoreDeprecations": "6.0",
        "paths": {
            "solid-js/jsx-dev-runtime": ["src/solid-js/jsx-dev-runtime.d.ts"],
            "solid-js/jsx-runtime": ["src/solid-js/jsx-runtime.d.ts"]
        },
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "types": ["bun"],
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "src/ui/_.css"],
    "exclude": ["src/**/*.test.ts"],
}
