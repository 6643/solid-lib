{
    "name": "solid-lib",
    "version": "0.0.0",
    "type": "module",
    "bin": {
        "solid-build": "./src/builder/build.ts",
        "solid-dev": "./src/builder/dev.ts"
    },
    "exports": {
        "./builder": {
            "types": "./src/builder/_.ts",
            "import": "./src/builder/_.ts"
        },
        "./route": {
            "types": "./src/route/_.ts",
            "import": "./src/route/_.ts"
        },
        "./ui": {
            "types": "./src/ui/_.ts",
            "import": "./src/ui/_.ts"
        },
        "./ui.css": "./src/ui/_.css"
    },
    "files": [
        "docs",
        "src",
        "README.md",
        "tsconfig.json"
    ],
    "scripts": {
        "test": "bun run test:unit",
        "test:local-consumer": "bun ./test/demo-local-consumer.ts",
        "test:packed-consumer": "bun ./test/demo-local-consumer.ts pack",
        "test:smoke": "bun run test:local-consumer && bun run test:packed-consumer",
        "test:unit": "bun test"
    },
    "dependencies": {
        "@babel/core": "7.29.0",
        "@babel/preset-typescript": "7.28.5",
        "babel-preset-solid": "2.0.0-beta.6",
        "dom-expressions": "0.40.6",
        "typescript": "6.0.2"
    },
    "devDependencies": {
        "@types/babel__core": "7.20.5",
        "@types/bun": "1.3.12",
        "solid-js": "2.0.0-beta.6"
    },
    "peerDependencies": {
        "solid-js": "2.0.0-beta.6"
    }
}
